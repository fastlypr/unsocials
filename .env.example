# Unsocials lead qualifier — environment file.
# Copy this to .env and fill in real values. .env is gitignored.

# --- Notion (OPTIONAL) -------------------------------------------------------
# If BOTH are set, each lead is written to Notion in addition to the CSVs.
# If either is missing, the scripts run CSV-only (results/ folder still filled).

# Notion integration token. Create one at https://www.notion.so/profile/integrations
# Must be shared with the target database (Notion DB → ••• → Connections).
# NOTION_TOKEN=ntn_REPLACE_ME

# Notion database id. Open the DB as a full page; the id is the 32-char hex
# string in the URL between the workspace slug and the "?v=" query.
# NOTION_DB_ID=REPLACE_ME

# --- Optional ----------------------------------------------------------------

# Lead source when nothing is passed on the CLI. Use ONE of:
#   LEADS_FILE — path to a local .json or .csv file
#   SHEET_URL  — a PUBLIC Google Sheet ("Anyone with the link can view")
# A CLI arg (file path or sheet URL) overrides both.
# LEADS_FILE=leads.csv
# SHEET_URL=https://docs.google.com/spreadsheets/d/XXXXXXXX/edit#gid=0

# Output folder for the result CSVs (default ./results). The scripts write:
#   results/qualified.csv                    — qualified leads
#   results/disqualified_needs_review.csv    — disqualified + needs-review leads
#   results/errors.csv                       — leads that failed (retried on resume)
# RESULTS_DIR=results

# Auto-resume: skip leads already written successfully (present in qualified or
# disqualified_needs_review with no error). On by default. Set to 0 to
# reprocess everything (or just delete the results/ folder).
# RESUME=1

# Parallel lead processing (qualify_leads_zen.js only). Default 1 = sequential.
# Higher = faster, until you hit the model's rate limit. The DeepSeek V4 Flash
# Go plan allows ~31,650 requests per 5-hour window, so 5–10 is very safe.
#   CONCURRENCY=5   ~5x speedup
#   CONCURRENCY=10  ~10x speedup (risk of 429s rises; retry/backoff handles them)
# CONCURRENCY=1

# --- Model + provider credentials -------------------------------------------
# OpenCode runs the model, so it needs the provider's API key. Pick ONE path:
#
#  PATH A (simplest, no key in this file): let OpenCode store the key itself.
#     opencode auth login         # choose DeepSeek, paste your key
#     -> saved to ~/.local/share/opencode/auth.json. Leave the keys below blank.
#
#  PATH B (keep the key here in .env): set DEEPSEEK_API_KEY below. The project
#     opencode.json maps it via {env:DEEPSEEK_API_KEY}, and the CLI script
#     passes this .env through to the `opencode` subprocess automatically.
#     NOTE: for the API runner you start `opencode serve` yourself, so that
#     shell must also have the key:  export DEEPSEEK_API_KEY=...  (or use PATH A).

# There are THREE runners:
#   qualify_leads_zen.js  — calls OpenCode Zen API directly. No opencode binary
#                           needed. Simplest. Uses OPENCODE_API_KEY below.
#   qualify_leads.js      — shells out to the `opencode` CLI (must be installed).
#   qualify_leads_api.js  — talks to `opencode serve` over HTTP.

# OpenCode API key. For an OpenCode Go subscription this is your Go key.
OPENCODE_API_KEY=sk-REPLACE_ME

# Endpoint. OpenCode Go (subscription) vs pay-as-you-go Zen (credits):
#   Go:   https://opencode.ai/zen/go/v1   <- subscription, has deepseek-v4-pro
#   Zen:  https://opencode.ai/zen/v1      <- pay-as-you-go credits
# The qualify_leads_zen.js runner defaults to the Go endpoint.
ZEN_BASE_URL=https://opencode.ai/zen/go/v1

# Model. The Zen runner strips the "opencode/" or "opencode-go/" prefix.
# On the Go plan:
#   opencode-go/deepseek-v4-pro     (reasoning model; best quality)
#   opencode-go/deepseek-v4-flash   (cheaper/faster; more requests per limit)
OPENCODE_MODEL=opencode-go/deepseek-v4-pro

# Optional override of just the bare model id for the Zen runner:
# ZEN_MODEL=deepseek-v4-flash

# OpenCode agent name, if you wrapped the skill inside an agent.
# OPENCODE_AGENT=

# Per-lead timeout in seconds (default 600). Used by both scripts.
# OPENCODE_TIMEOUT=600

# --- API script only (qualify_leads_api.js) ---------------------------------

# Where qualify_leads_api.js connects to `opencode serve`. Defaults shown.
# OPENCODE_HOST=127.0.0.1
# OPENCODE_PORT=4096

# Optional HTTP basic auth, only if you started the server with
# OPENCODE_SERVER_PASSWORD=... opencode serve
# OPENCODE_USER=opencode
# OPENCODE_PASSWORD=
